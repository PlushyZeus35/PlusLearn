if successes
    for success in successes
        .toast-container.position-fixed.bottom-0.end-0.m-4(style='z-index: 11')
            .toast.align-items-center.text-white.bg-danger.border-0.show(role="alert" aria-live="assertive" aria-atomic="true")
                .d-flex
                    .toast-body 
                        strong #{success}
                    button.btn-close.btn-close-white.me-2.m-auto(type='button' data-bs-dismiss='toast' aria-label='Close')


if messages 
    for message in messages
        .toast-container.position-fixed.bottom-0.end-0.m-4(style='z-index: 11')
            .toast.align-items-center.text-white.bg-danger.border-0.show(role="alert" aria-live="assertive" aria-atomic="true")
                .d-flex
                    .toast-body 
                        strong #{message}
                    button.btn-close.btn-close-white.me-2.m-auto(type='button' data-bs-dismiss='toast' aria-label='Close')