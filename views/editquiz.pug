doctype html
head
    meta(charset='UTF-8')
    meta(http-equiv='X-UA-Compatible' content='IE=edge')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Document
    script(src='https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js')
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3' crossorigin='anonymous')
    link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css')
    //link(rel='stylesheet' href='/static/css/style.css')
body
    // Flash messages
    include ./includes/messages

    // NAVBAR!!
    nav.navbar.navbar-dark.bg-dark.fixed-top.text-white
        .container-fluid
            button#sidebar-toggler.navbar-toggler.b-0(type='button')
                svg.feather.feather-menu(xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewbox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
                    line(x1='3' y1='12' x2='21' y2='12')
                    line(x1='3' y1='6' x2='21' y2='6')
                    line(x1='3' y1='18' x2='21' y2='18')
            h4.mx-auto Quiz #{quiz.name}
    
    // ADD QUIZ MODAL!
    #addQuestionModal.modal.fade(tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true")
        .modal-dialog.modal-dialog-centered.modal-fullscreen-sm-down
            .modal-content 
                .modal-header 
                    h3 Crear nueva question
                    button(type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close")
                .modal-body 
                    form(action="/question/add" method="POST")
                        .mb-3 
                        label(for="questionNameInput" class="form-label") Pregunta:
                        input(type="text" name="questionName" class="form-control" id="questionNameInput")
                        .mb-3 
                        label(for="correctResponseInput" class="form-label") Respuesta correcta:
                        input(type="text" name="correctAnswer" class="form-control" id="correctResponseInput")
                        .mb-3 
                        label(for="incorrectResponseInput1" class="form-label") Respuesta incorrecta:
                        input(type="text" name="incorrectAnswer1" class="form-control" id="incorrectResponseInput1")
                        .mb-3 
                        label(for="incorrectResponseInput2" class="form-label") Respuesta incorrecta:
                        input(type="text" name="incorrectAnswer2" class="form-control" id="incorrectResponseInput2")
                        .mb-0
                        label(for="incorrectResponseInput3" class="form-label") Respuesta incorrecta:
                        input(type="text" name="incorrectAnswer3" class="form-control" id="incorrectResponseInput3")
                        input(type="text" name="quizId" class="form-control d-none" value=`${quiz.id}`)
                        .modal-footer
                        button(type="button" class="btn btn-secondary" data-bs-dismiss="modal") Close
                        button(type="submit" class="btn btn-primary") Save changes

    // MAIN DIV
    #main.container-fluid(style='margin-top: 100px;')
        #questions.container.mt-4 
            .container-fluid.d-flex.justify-content-between#questionstitle
                h3 Questions
                - deleteUrl = "/quiz/delete?quizId=" + quiz.id
                div
                    button.btn.btn-primary(data-bs-toggle="modal" data-bs-target="#addQuestionModal") Añadir question
                    a.btn.btn-danger(href=`${deleteUrl}`) Eliminar quiz
            hr
            #questionAccordion.accordion 
                .accordion-item 
                    h2#heading.accordion-header 
                        button.accordion-button(type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne")
                            | Q #1: ¿Cuál es la palabra mágica?
                    #collapseOne.accordion-collapse.collapse(aria-labelledby="heading" data-bs-parent="#questionAccordion")
                        .accordion-body 
                            ul.list-group 
                                li.list-group-item
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="green" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="feather feather-check"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                    | Muchas gracias 
                                li.list-group-item
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="red" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="feather feather-x"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg> 
                                    | Olvidona 
                                li.list-group-item 
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="red" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="feather feather-x"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                    | No quiero saber nada de esto 
                                li.list-group-item 
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="red" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="feather feather-x"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                    | Dame todo tu dinero pero sin que nadie lo sepa! Gracias!
    script(src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.5/dist/umd/popper.min.js" integrity="sha384-Xe+8cL9oJa6tN/veChSP7q+mnSPaj5Bcu9mPX5F5xIGE0DVittaqT5lorf0EI7Vk" crossorigin="anonymous")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/js/bootstrap.min.js" integrity="sha384-kjU+l4N0Yf4ZOJErLsIcvOU2qSb74wXpOhqTvwVx3OElZRweTnQ6d31fXEoRD1Jy" crossorigin="anonymous")